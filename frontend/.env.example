# ---- Frontend environment (copy to .env.local; never commit it) ----
# Both values are SERVER-SIDE only (no NEXT_PUBLIC_ prefix): the browser talks
# to the same-origin proxy at /api/insights/*, which injects the token.

# Base URL of the FastAPI backend.
API_BASE_URL=http://localhost:8000

# Insights API bearer token. MUST match DASHBOARD_AUTH_TOKEN in the backend .env.
DASHBOARD_AUTH_TOKEN=replace-with-the-same-token-as-backend
