# ---- Backend environment (copy to .env; never commit .env) ----
# This template is committed. Put REAL secrets only in .env (gitignored).

# Neon Postgres. Copy the connection string from the Neon dashboard.
# Either postgres:// or postgresql:// works — the app rewrites it to asyncpg
# and strips libpq-only params (sslmode/channel_binding) automatically.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname

# TLS for the DB connection. true for Neon; false for a local Postgres without TLS.
DB_SSL=true

# Linear personal API key (Linear → Settings → Security & access → Personal API keys).
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Bearer token the frontend sends to call the insights API. Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_AUTH_TOKEN=replace-with-a-long-random-token

# Comma-separated allowed CORS origins (frontend URLs).
CORS_ORIGINS=http://localhost:3000

# development | production
ENVIRONMENT=development
